NODE_ENV=development
PORT=5000

# Mongo
MONGODB_URL=mongodb://localhost:27017/service_platform

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDNAME=
CLOUD_KEY=
CLOUD_SECRET_KEY=

# Root domain — client sites served at <slug>.<ROOT_DOMAIN>
ROOT_DOMAIN=yoursite.com

# CORS allowed origins (comma separated). Use "*" to allow all in dev.
CORS_ORIGINS=*

# Default super-admin seeded by `npm run seed:admin`
SEED_ADMIN_EMAIL=admin@yoursite.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=Super Admin
